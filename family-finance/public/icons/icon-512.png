<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <!-- Background -->
  <rect width="512" height="512" rx="100" fill="#064e3b"/>
  <!-- House body -->
  <polygon points="256,80 400,200 400,420 112,420 112,200" fill="none" stroke="#6ee7b7" stroke-width="18" stroke-linejoin="round"/>
  <!-- Roof -->
  <polygon points="256,80 420,210 92,210" fill="#6ee7b7"/>
  <!-- Door -->
  <rect x="196" y="290" width="120" height="130" rx="10" fill="#6ee7b7"/>
  <!-- GHS symbol -->
  <text x="256" y="370" text-anchor="middle" font-family="Arial, sans-serif" font-size="64" font-weight="900" fill="#064e3b">₵</text>
</svg>
